{
  "name": "mnlth",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "setup": "bun install && bun run --cwd packages/backend setup && bun run env:sync",
    "env:sync": "bun scripts/sync-env.ts",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "version-packages": "changeset version && bun install",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/pg": "^8.20.0",
    "lefthook": "^2.1.9",
    "pg": "^8.22.0",
    "sst": "^4.17.0",
    "turbo": "^2.9.18",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "convex": "^1.42.1"
    }
  }
}
